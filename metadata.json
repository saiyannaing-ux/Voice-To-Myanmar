
import React, { useState, useCallback, useRef, useEffect } from 'react';
import { AppStatus, AppState, SavedSession } from './types';
import { createLiveSession, refineMyanmarText } from './services/geminiService';
import { createPcmBlob } from './services/audioUtils';
import { AudioVisualizer } from './components/AudioVisualizer';
import { 
  Mic, 
  Square, 
  Copy, 
  Sparkles, 
  RotateCcw, 
  CheckCircle2, 
  AlertCircle,
  MessageSquareQuote,
  Languages,
  Save,
  History,
  Trash2,
  ExternalLink,
  Clock
} from 'lucide-react';

const STORAGE_KEY = 'myanmar_scribe_history';
const DRAFT_KEY = 'myanmar_scribe_draft';

const App: React.FC = () => {
  const [state, setState] = useState<AppState>({
    status: AppStatus.IDLE,
    rawText: '',
    refinedText: '',
    history: [],
    error: null,
  });

  const [stream, setStream] = useState<MediaStream | null>(null);
  const [copied, setCopied] = useState(false);
  const [saveSuccess, setSaveSuccess] = useState(false);
  
  const sessionRef = useRef<any>(null);
  const audioContextRef = useRef<AudioContext | null>(null);
  const scriptProcessorRef = useRef<ScriptProcessorNode | null>(null);

  // Load history and draft from localStorage on mount
  useEffect(() => {
    const savedHistory = localStorage.getItem(STORAGE_KEY);
    const savedDraft = localStorage.getItem(DRAFT_KEY);
    
    setState(prev => ({
      ...prev,
      history: savedHistory ? JSON.parse(savedHistory) : [],
      ...(savedDraft ? JSON.parse(savedDraft) : {})
    }));
  }, []);

  // Persist draft to localStorage whenever raw/refined text changes
  useEffect(() => {
    if (state.rawText || state.refinedText) {
      localStorage.setItem(DRAFT_KEY, JSON.stringify({
        rawText: state.rawText,
        refinedText: state.refinedText
      }));
    }
  }, [state.rawText, state.refinedText]);

  // Persist history to localStorage
  useEffect(() => {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(state.history));
  }, [state.history]);

  const cleanup = useCallback(() => {
    if (scriptProcessorRef.current) {
      scriptProcessorRef.current.disconnect();
      scriptProcessorRef.current = null;
    }
    if (audioContextRef.current) {
      audioContextRef.current.close();
      audioContextRef.current = null;
    }
    if (stream) {
      stream.getTracks().forEach(track => track.stop());
      setStream(null);
    }
    if (sessionRef.current) {
      sessionRef.current = null;
    }
  }, [stream]);

  const startTranscription = async () => {
    try {
      cleanup();
      const userStream = await navigator.mediaDevices.getUserMedia({ audio: true });
      setStream(userStream);

      const sessionPromise = createLiveSession({
        onTranscription: (text) => {
          setState(prev => ({
            ...prev,
            rawText: prev.rawText + (prev.rawText ? ' ' : '') + text
          }));
        },
        onError: (err) => {
          console.error(err);
          setState(prev => ({ ...prev, status: AppStatus.ERROR, error: 'Transcription error occurred.' }));
          cleanup();
        },
        onClose: () => {
          setState(prev => ({ ...prev, status: AppStatus.IDLE }));
          cleanup();
        }
      });

      sessionRef.current = sessionPromise;

      const audioContext = new (window.AudioContext || (window as any).webkitAudioContext)({ sampleRate: 16000 });
      audioContextRef.current = audioContext;

      const source = audioContext.createMediaStreamSource(userStream);
      const scriptProcessor = audioContext.createScriptProcessor(4096, 1, 1);
      scriptProcessorRef.current = scriptProcessor;

      scriptProcessor.onaudioprocess = (e) => {
        const inputData = e.inputBuffer.getChannelData(0);
        const pcmBlob = createPcmBlob(inputData);
        sessionPromise.then(session => {
          session.sendRealtimeInput({ media: pcmBlob });
        });
      };

      source.connect(scriptProcessor);
      scriptProcessor.connect(audioContext.destination);

      setState(prev => ({ ...prev, status: AppStatus.RECORDING, error: null }));
    } catch (err) {
      console.error(err);
      setState(prev => ({ ...prev, status: AppStatus.ERROR, error: 'Could not access microphone.' }));
    }
  };

  const stopTranscription = () => {
    cleanup();
    setState(prev => ({ ...prev, status: AppStatus.IDLE }));
  };

  const handleRefine = async () => {
    if (!state.rawText) return;
    setState(prev => ({ ...prev, status: AppStatus.REFINING }));
    try {
      const refined = await refineMyanmarText(state.rawText);
      setState(prev => ({ ...prev, refinedText: refined, status: AppStatus.IDLE }));
    } catch (err) {
      setState(prev => ({ ...prev, status: AppStatus.IDLE, error: 'Failed to refine text.' }));
    }
  };

  const saveToHistory = () => {
    if (!state.rawText && !state.refinedText) return;
    
    const newSession: SavedSession = {
      id: crypto.randomUUID(),
      rawText: state.rawText,
      refinedText: state.refinedText,
      timestamp: Date.now(),
    };

    setState(prev => ({
      ...prev,
      history: [newSession, ...prev.history].slice(0, 20) // Keep last 20 sessions
    }));

    setSaveSuccess(true);
    setTimeout(() => setSaveSuccess(false), 2000);
  };

  const loadSession = (session: SavedSession) => {
    if (state.status === AppStatus.RECORDING) {
        stopTranscription();
    }
    setState(prev => ({
      ...prev,
      rawText: session.rawText,
      refinedText: session.refinedText
    }));
    window.scrollTo({ top: 0, behavior: 'smooth' });
  };

  const deleteSession = (id: string, e: React.MouseEvent) => {
    e.stopPropagation();
    setState(prev => ({
      ...prev,
      history: prev.history.filter(s => s.id !== id)
    }));
  };

  const copyToClipboard = (text: string) => {
    navigator.clipboard.writeText(text);
    setCopied(true);
    setTimeout(() => setCopied(false), 2000);
  };

  const resetAll = () => {
    cleanup();
    localStorage.removeItem(DRAFT_KEY);
    setState(prev => ({
      ...prev,
      status: AppStatus.IDLE,
      rawText: '',
      refinedText: '',
      error: null,
    }));
  };

  const formatDate = (ts: number) => {
    return new Intl.DateTimeFormat('en-GB', {
      day: '2-digit',
      month: 'short',
      hour: '2-digit',
      minute: '2-digit'
    }).format(ts);
  };

  return (
    <div className="min-h-screen flex flex-col items-center p-4 md:p-8">
      <header className="w-full max-w-5xl mb-8 flex items-center justify-between">
        <div className="flex items-center gap-3">
          <div className="bg-blue-600 p-2.5 rounded-xl shadow-lg shadow-blue-200">
            <MessageSquareQuote className="w-6 h-6 text-white" />
          </div>
          <div>
            <h1 className="text-2xl font-bold text-slate-800">Myanmar Voice Scribe</h1>
            <div className="flex items-center gap-1.5 text-xs font-semibold text-blue-500 uppercase tracking-tighter">
              <Languages className="w-3 h-3" />
              Bilingual: Myanmar + English
            </div>
          </div>
        </div>
        <button 
          onClick={resetAll}
          className="flex items-center gap-2 px-4 py-2 text-sm font-semibold text-slate-500 hover:text-red-600 transition-colors"
        >
          <RotateCcw className="w-4 h-4" />
          Clear Workspace
        </button>
      </header>

      <main className="w-full max-w-5xl space-y-6">
        {/* Controls Section */}
        <div className="bg-white p-6 rounded-3xl shadow-sm border border-slate-100 flex flex-col md:flex-row items-center gap-6">
          <div className="flex-1 w-full">
            <AudioVisualizer isRecording={state.status === AppStatus.RECORDING} stream={stream} />
          </div>
          
          <div className="flex items-center gap-4">
            {state.status === AppStatus.RECORDING ? (
              <button
                onClick={stopTranscription}
                className="flex items-center gap-2 bg-red-500 hover:bg-red-600 text-white px-6 py-3 rounded-2xl font-bold shadow-lg shadow-red-200 transition-all active:scale-95"
              >
                <Square className="w-5 h-5 fill-current" />
                Stop
              </button>
            ) : (
              <button
                onClick={startTranscription}
                className="flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-2xl font-bold shadow-lg shadow-blue-200 transition-all active:scale-95"
              >
                <Mic className="w-5 h-5" />
                Start
              </button>
            )}

            <button
              onClick={handleRefine}
              disabled={!state.rawText || state.status === AppStatus.RECORDING || state.status === AppStatus.REFINING}
              className={`flex items-center gap-2 px-6 py-3 rounded-2xl font-bold transition-all active:scale-95 ${
                !state.rawText || state.status === AppStatus.RECORDING || state.status === AppStatus.REFINING
                  ? 'bg-slate-100 text-slate-400 cursor-not-allowed'
                  : 'bg-indigo-600 hover:bg-indigo-700 text-white shadow-lg shadow-indigo-200'
              }`}
            >
              <Sparkles className={`w-5 h-5 ${state.status === AppStatus.REFINING ? 'animate-spin' : ''}`} />
              {state.status === AppStatus.REFINING ? 'Refining...' : 'Refine'}
            </button>

            <button
              onClick={saveToHistory}
              disabled={(!state.rawText && !state.refinedText) || state.status === AppStatus.RECORDING}
              className="p-3 bg-emerald-50 text-emerald-600 hover:bg-emerald-100 rounded-2xl transition-colors disabled:opacity-30 disabled:cursor-not-allowed"
              title="Save to History"
            >
              <Save className="w-6 h-6" />
            </button>
          </div>
        </div>

        {state.error && (
          <div className="bg-red-50 border border-red-100 p-4 rounded-2xl flex items-center gap-3 text-red-700">
            <AlertCircle className="w-5 h-5" />
            <p className="text-sm font-medium">{state.error}</p>
          </div>
        )}

        {/* Display Section */}
        <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
          {/* Raw Transcription */}
          <section className="bg-white rounded-3xl shadow-sm border border-slate-100 flex flex-col overflow-hidden h-[450px]">
            <div className="p-4 border-b border-slate-50 bg-slate-50/50 flex items-center justify-between">
              <h2 className="text-sm font-bold text-slate-600 uppercase tracking-wider">Raw Transcription</h2>
              <div className="flex items-center gap-2">
                 <span className="text-[10px] bg-blue-100 text-blue-700 px-2 py-0.5 rounded-full font-bold">AUTO-DETECT</span>
                 <button 
                  onClick={() => copyToClipboard(state.rawText)}
                  disabled={!state.rawText}
                  className="p-2 hover:bg-white rounded-lg transition-colors text-slate-400 hover:text-blue-600 disabled:opacity-30"
                  title="Copy raw text"
                >
                  <Copy className="w-5 h-5" />
                </button>
              </div>
            </div>
            <div className="p-6 flex-1 overflow-y-auto myanmar-text text-lg text-slate-800">
              {state.rawText || (
                <div className="h-full flex flex-col items-center justify-center text-slate-400 space-y-2 opacity-50">
                  <Mic className="w-10 h-10" />
                  <p className="text-center px-4">Speak in Myanmar or English.<br/>Transcription starts automatically.</p>
                </div>
              )}
              {state.status === AppStatus.RECORDING && (
                <span className="inline-block w-2 h-2 bg-red-500 rounded-full animate-pulse ml-2" />
              )}
            </div>
          </section>

          {/* Refined Text */}
          <section className="bg-white rounded-3xl shadow-sm border border-slate-100 flex flex-col overflow-hidden h-[450px]">
            <div className="p-4 border-b border-slate-50 bg-slate-50/50 flex items-center justify-between">
              <h2 className="text-sm font-bold text-slate-600 uppercase tracking-wider">Natural Grammar Edit</h2>
              <button 
                onClick={() => copyToClipboard(state.refinedText)}
                disabled={!state.refinedText}
                className="p-2 hover:bg-white rounded-lg transition-colors text-slate-400 hover:text-indigo-600 disabled:opacity-30"
                title="Copy refined text"
              >
                <Copy className="w-5 h-5" />
              </button>
            </div>
            <div className="p-6 flex-1 overflow-y-auto myanmar-text text-lg text-slate-800 bg-indigo-50/10">
              {state.status === AppStatus.REFINING ? (
                 <div className="h-full flex flex-col items-center justify-center text-indigo-400 space-y-4">
                    <Sparkles className="w-10 h-10 animate-pulse" />
                    <p className="font-medium">Optimizing bilingual flow...</p>
                 </div>
              ) : state.refinedText ? (
                <div className="relative group">
                  <p>{state.refinedText}</p>
                </div>
              ) : (
                <div className="h-full flex flex-col items-center justify-center text-slate-400 space-y-2 opacity-50">
                  <Sparkles className="w-10 h-10" />
                  <p className="text-center px-4">Refined text will handle<br/>Myanmar and English context.</p>
                </div>
              )}
            </div>
          </section>
        </div>

        {/* History Section */}
        <section className="mt-12 space-y-4">
            <div className="flex items-center gap-3 px-2">
                <History className="w-5 h-5 text-slate-400" />
                <h2 className="text-lg font-bold text-slate-700">Recent Sessions</h2>
            </div>
            
            {state.history.length === 0 ? (
                <div className="bg-slate-50 border-2 border-dashed border-slate-200 p-12 rounded-3xl text-center text-slate-400">
                    <p className="text-sm">No saved sessions yet. Transcribe and click "Save" to keep them here.</p>
                </div>
            ) : (
                <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                    {state.history.map(session => (
                        <div 
                            key={session.id}
                            onClick={() => loadSession(session)}
                            className="bg-white p-5 rounded-2xl border border-slate-100 shadow-sm hover:shadow-md hover:border-blue-100 transition-all cursor-pointer group relative"
                        >
                            <div className="flex justify-between items-start mb-3">
                                <div className="flex items-center gap-2 text-xs font-medium text-slate-400">
                                    <Clock className="w-3 h-3" />
                                    {formatDate(session.timestamp)}
                                </div>
                                <button 
                                    onClick={(e) => deleteSession(session.id, e)}
                                    className="p-1.5 text-slate-300 hover:text-red-500 rounded-lg hover:bg-red-50 transition-colors opacity-0 group-hover:opacity-100"
                                >
                                    <Trash2 className="w-4 h-4" />
                                </button>
                            </div>
                            <p className="myanmar-text text-sm text-slate-600 line-clamp-3 mb-1">
                                {session.refinedText || session.rawText}
                            </p>
                            <div className="flex items-center gap-1.5 mt-3 pt-3 border-t border-slate-50 text-[10px] font-bold text-blue-500 uppercase tracking-widest">
                                <ExternalLink className="w-3 h-3" />
                                Load Session
                            </div>
                        </div>
                    ))}
                </div>
            )}
        </section>
      </main>

      {/* Notifications */}
      {copied && (
        <div className="fixed bottom-8 left-1/2 -translate-x-1/2 bg-slate-900 text-white px-6 py-3 rounded-full flex items-center gap-3 shadow-2xl z-50 animate-in fade-in slide-in-from-bottom-4 duration-300">
          <CheckCircle2 className="w-5 h-5 text-green-400" />
          <span className="font-medium">Copied to clipboard</span>
        </div>
      )}

      {saveSuccess && (
        <div className="fixed bottom-8 left-1/2 -translate-x-1/2 bg-emerald-600 text-white px-6 py-3 rounded-full flex items-center gap-3 shadow-2xl z-50 animate-in fade-in slide-in-from-bottom-4 duration-300">
          <Save className="w-5 h-5 text-emerald-100" />
          <span className="font-medium">Session saved to history</span>
        </div>
      )}

      <footer className="mt-20 text-slate-400 text-sm pb-8 flex flex-col items-center gap-1 text-center max-w-lg">
        <div className="flex items-center gap-2 mb-2">
            <span className="w-2 h-2 rounded-full bg-blue-500 animate-pulse"></span>
            <span className="text-[10px] uppercase font-black tracking-[0.2em] text-slate-400">System Live</span>
        </div>
        <span>Optimized for Code-Switching (MM/EN) • Auto-Drafting Enabled</span>
      </footer>
    </div>
  );
};

export default App;
